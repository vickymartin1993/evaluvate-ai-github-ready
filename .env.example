# ============================================================
# Evaluvate AI — Frontend Environment Variables
# ============================================================
# HOW TO USE:
#   cp .env.example .env.local
#   Fill in your values in .env.local
#   NEVER commit .env.local — it is in .gitignore
#
# In Vite, only vars prefixed VITE_ are available in the browser.
# Never prefix backend secrets (Cosmos, Azure Storage keys) with VITE_.
# ============================================================

# ----- BACKEND API -----
# Local dev: Azure Functions runs here by default
# Production: Set this in Azure Static Web Apps environment settings (not here)
VITE_API_BASE_URL=http://localhost:7071/api

# ----- FEATURE FLAGS -----
# Set to "true" one at a time as each backend feature is ready.
# This lets you develop/test one slice without breaking the rest of the UI.
VITE_FEATURE_REAL_UPLOAD=false      # true = UploadPage calls real Blob SAS API
VITE_FEATURE_REAL_SCORING=false     # true = GradingPage shows real Cosmos AI scores
VITE_FEATURE_REAL_AUTH=false        # true = Login required, JWT attached to all requests

# ----- SCHOOL CONTEXT (POC only — replace with auth in Sprint 4) -----
# During POC, hardcode the school ID here so all API calls scope to one school.
# When real auth is wired, this comes from the JWT instead.
VITE_POC_SCHOOL_ID=school_poc_001
