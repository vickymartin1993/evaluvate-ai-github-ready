# ============================================================
# Evaluvate AI — Backend Environment Variables
# ============================================================
# HOW TO USE:
#   cp backend/.env.example backend/.env
#   Fill in real values
#   NEVER commit backend/.env — it is in .gitignore
#
# For Azure Functions local dev, these ALSO go into:
#   backend/local.settings.json  (also in .gitignore)
#
# For production, set these in:
#   Azure Portal → Function App → Configuration → Application Settings
#   OR inject via GitHub Actions secrets into the deploy workflow
# ============================================================

# ----- GOOGLE AI (PRIMARY SCORER) -----
# Free tier: 15 req/min, 1M tokens/day — sufficient for POC
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Which Gemini model to use
# gemini-2.5-flash = fast + cheap (use this)
# gemini-2.5-pro   = more accurate but slower and costs more (use for hard cases only)
GEMINI_MODEL=gemini-2.5-flash

# ----- AZURE OPENAI (FALLBACK SCORER — only used when Gemini fails) -----
# Get from: Azure Portal → OpenAI resource → Keys and Endpoint
# Leave blank during POC if you haven't provisioned Azure OpenAI yet —
# the code will skip the fallback and flag the sheet for manual review instead.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ----- AZURE COSMOS DB -----
# Get from: Azure Portal → Cosmos DB account → Keys → Primary Connection String
# For local dev you can use the Cosmos DB emulator (free):
#   https://docs.microsoft.com/en-us/azure/cosmos-db/local-emulator
COSMOS_CONNECTION_STRING=AccountEndpoint=https://localhost:8081/;AccountKey=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMxZw==

# The prefix for all school database names in Cosmos
# e.g., school_st_josephs, school_don_bosco
COSMOS_DB_PREFIX=school_

# ----- AZURE BLOB STORAGE -----
# Get from: Azure Portal → Storage Account → Access keys → Connection string
# For local dev, use Azurite (the local emulator):
#   npm install -g azurite && azurite --silent --location ./azurite-data
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OGLHnZKcjREc1y96ou1nJMkY2mBd3mxH3ePpgSi6fU1xFY2mT/lw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

# Container names — created automatically by provision-school.sh
AZURE_STORAGE_ANSWER_SHEETS_CONTAINER=answer-sheets
AZURE_STORAGE_ANSWER_KEYS_CONTAINER=answer-keys

# How long (minutes) the SAS upload URL is valid before expiry
# Teachers should upload within this window after requesting the URL
AZURE_STORAGE_SAS_EXPIRY_MINUTES=15

# ----- AI PIPELINE SETTINGS -----
# Questions with confidence below this threshold trigger the GPT-4o fallback call.
# Range: 0.0 to 1.0
# Lower = more fallback calls (more accurate but costs more with GPT-4o)
# Higher = fewer fallback calls (cheaper but more low-confidence questions reach teacher)
CONFIDENCE_THRESHOLD=0.70

# Maximum pages of an answer sheet to send to Gemini in one call.
# Gemini 2.5 Flash supports up to 3600 image pages per request, but
# for cost control we process in batches of this size.
MAX_PAGES_PER_BATCH=10

# ----- COST TRACKING -----
# Used to convert USD AI costs to INR in usage_events records.
# Update this every few months — does not need to be exact.
USD_TO_INR_RATE=83.5

# ----- ENVIRONMENT -----
# "development" | "production"
NODE_ENV=development
