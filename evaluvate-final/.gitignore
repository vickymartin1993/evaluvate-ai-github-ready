# ============================================================
# Evaluvate AI — .gitignore
# CRITICAL: .env files contain API keys. They must NEVER be committed.
# If you accidentally commit a secret, rotate the key immediately.
# ============================================================

# ----- SECRETS & ENV FILES (NEVER commit these) -----
.env
.env.local
.env.*.local
.env.production
backend/.env
backend/local.settings.json

# ----- NODE -----
node_modules/
backend/node_modules/

# ----- BUILD OUTPUTS -----
dist/
dist-ssr/
backend/dist/

# ----- LOGS -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# ----- EDITOR -----
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ----- TEST ARTIFACTS -----
coverage/
playwright-report/
test-results/
