{
  "name": "evaluvate-backend",
  "version": "0.1.0",
  "description": "Evaluvate AI — Azure Functions backend (Node.js + TypeScript)",
  "private": true,
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "npm run build && func start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/cosmos": "^4.1.1",
    "@azure/storage-blob": "^12.24.0",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.77.0",
    "uuid": "^9.0.0",
    "zod": "^3.25.0",
    "pdf-to-img": "^4.2.0"
  },
  "devDependencies": {
    "@azure/functions": "^4.5.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
